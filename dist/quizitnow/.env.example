# QuizItNow Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# LOCAL FEATURES (No configuration needed)
# ============================================
# The app works completely locally:
# - Quiz generation ✅
# - PDF extraction ✅
# - Image OCR ✅
# - Quiz taking with timer ✅
# - Results page ✅

# ============================================
# OPTIONAL: Supabase (for authentication & history)
# ============================================
# Get these from: https://supabase.com
# Create a new project and copy these values
# These are OPTIONAL - the app works without them

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# After setting these:
# 1. Create tables using the SQL migrations
# 2. Enable authentication in Supabase
# 3. Users can now save quiz history and create accounts
